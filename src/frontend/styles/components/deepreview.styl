// DeepReview component styles.
//
// Layout: three-panel design with file list sidebar (left),
// editor area with sliders (center), and call trace panel (right).

.deepreview-container
  display flex
  flex-direction column
  height 100%
  width 100%
  overflow hidden
  font-family 'SpaceGrotesk', sans-serif

// --- Header ---

.deepreview-header
  display flex
  justify-content space-between
  align-items center
  padding 6px 16px
  background-color var(--bg-secondary, #1e1f26)
  border-bottom 1px solid var(--border-color, #3a3b44)
  flex-shrink 0

.deepreview-commit
  font-size 13px
  color var(--text-primary, #c9c9c9)

.deepreview-stats
  font-size 12px
  color var(--text-secondary, #8e8f92)

.deepreview-error
  padding 24px
  font-size 14px
  color var(--text-secondary, #8e8f92)

// --- Body (three-panel layout) ---

.deepreview-body
  display flex
  flex 1
  overflow hidden

// --- File list sidebar ---

.deepreview-file-list
  width 250px
  min-width 180px
  overflow-y auto
  border-right 1px solid var(--border-color, #3a3b44)
  background-color var(--bg-primary, #1a1b22)
  flex-shrink 0

.deepreview-file-item
  padding 6px 12px
  cursor pointer
  border-bottom 1px solid var(--border-color, #2a2b34)
  transition background-color 0.15s ease

  &:hover
    background-color var(--bg-hover, #2a2b34)

  &.selected
    background-color var(--bg-selected, #333444)

.deepreview-file-name
  font-size 13px
  color var(--text-primary, #c9c9c9)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.deepreview-file-path-full
  font-size 11px
  color var(--text-secondary, #8e8f92)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis
  margin-top 2px

// --- File name row (status indicator + basename) ---

.deepreview-file-name-row
  display flex
  align-items center
  gap 6px

// --- Diff status indicator badge (A/M/D) ---

.deepreview-diff-status
  display inline-flex
  align-items center
  justify-content center
  width 18px
  height 18px
  font-size 11px
  font-weight bold
  border-radius 3px
  flex-shrink 0
  color var(--text-primary, #c9c9c9)
  background-color var(--bg-hover, #2a2b34)

  &.deepreview-diff-added
    color #3fb950
    background-color rgba(63, 185, 80, 0.15)

  &.deepreview-diff-modified
    color #d29922
    background-color rgba(210, 153, 34, 0.15)

  &.deepreview-diff-deleted
    color #f85149
    background-color rgba(248, 81, 73, 0.15)

// --- File badges row (diff lines + coverage) ---

.deepreview-file-badges
  display flex
  align-items center
  gap 6px
  margin-top 2px

// --- Diff line count badge (+N / -M) ---

.deepreview-diff-lines
  display inline-block
  font-size 11px
  color var(--text-secondary, #8e8f92)
  background-color var(--bg-hover, #2a2b34)
  padding 1px 6px
  border-radius 3px

  &.deepreview-diff-added
    color #3fb950

  &.deepreview-diff-modified
    color #d29922

  &.deepreview-diff-deleted
    color #f85149

.deepreview-coverage-badge
  display inline-block
  font-size 11px
  color var(--text-secondary, #8e8f92)
  background-color var(--bg-hover, #2a2b34)
  padding 1px 6px
  border-radius 3px

// --- Editor area ---

.deepreview-editor-area
  flex 1
  display flex
  flex-direction column
  min-width 0
  overflow hidden

.deepreview-editor
  flex 1
  min-height 0

// --- Sliders ---

.deepreview-slider
  display flex
  align-items center
  gap 8px
  padding 4px 12px
  background-color var(--bg-secondary, #1e1f26)
  border-bottom 1px solid var(--border-color, #3a3b44)
  flex-shrink 0
  font-size 12px
  color var(--text-secondary, #8e8f92)

.deepreview-slider-empty
  opacity 0.5

.deepreview-slider-label
  flex-shrink 0
  min-width 70px

.deepreview-slider-input
  flex 1
  cursor pointer

.deepreview-slider-info
  flex-shrink 0
  min-width 100px
  text-align right

// --- Call trace panel ---

.deepreview-calltrace
  width 280px
  min-width 200px
  overflow-y auto
  border-left 1px solid var(--border-color, #3a3b44)
  background-color var(--bg-primary, #1a1b22)
  flex-shrink 0

.deepreview-calltrace-header
  padding 8px 12px
  font-size 13px
  font-weight bold
  color var(--text-primary, #c9c9c9)
  border-bottom 1px solid var(--border-color, #3a3b44)
  background-color var(--bg-secondary, #1e1f26)

.deepreview-calltrace-body
  padding 4px 0

.deepreview-calltrace-empty
  padding 12px
  font-size 12px
  color var(--text-secondary, #8e8f92)
  font-style italic

.deepreview-calltrace-node
  font-size 12px

.deepreview-calltrace-entry
  padding 3px 8px
  cursor default

  &:hover
    background-color var(--bg-hover, #2a2b34)

.deepreview-calltrace-name
  color var(--text-primary, #c9c9c9)

.deepreview-calltrace-count
  color var(--text-secondary, #8e8f92)
  font-size 11px

// --- View mode toggle ---

.deepreview-mode-toggle
  display flex
  align-items center
  gap 0

.deepreview-mode-btn
  padding 3px 12px
  font-size 12px
  font-family 'SpaceGrotesk', sans-serif
  color var(--text-secondary, #8e8f92)
  background-color transparent
  border 1px solid var(--border-color, #3a3b44)
  cursor pointer
  transition background-color 0.15s ease, color 0.15s ease

  &:first-child
    border-radius 3px 0 0 3px

  &:last-child
    border-radius 0 3px 3px 0
    border-left none

  &:hover
    background-color var(--bg-hover, #2a2b34)
    color var(--text-primary, #c9c9c9)

  &.deepreview-mode-btn-active
    background-color var(--bg-selected, #333444)
    color var(--text-primary, #c9c9c9)
    border-color var(--border-color, #3a3b44)

// --- Unified diff view ---

.deepreview-unified-diff
  flex 1
  overflow-y auto
  padding 0

.deepreview-unified-empty
  padding 24px
  font-size 13px
  color var(--text-secondary, #8e8f92)
  font-style italic

.deepreview-unified-file
  margin-bottom 0
  border-bottom 1px solid var(--border-color, #3a3b44)

.deepreview-unified-file-header
  display flex
  align-items center
  gap 8px
  padding 6px 12px
  background-color var(--bg-secondary, #1e1f26)
  border-bottom 1px solid var(--border-color, #3a3b44)
  font-size 13px

.deepreview-unified-file-path
  color var(--text-primary, #c9c9c9)
  font-family 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace
  font-size 12px

.deepreview-unified-file-stats
  display flex
  gap 6px
  margin-left auto
  font-size 12px

.deepreview-unified-additions
  color #3fb950

.deepreview-unified-deletions
  color #f85149

.deepreview-unified-hunk
  font-family 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace
  font-size 12px
  line-height 20px

.deepreview-unified-hunk-header
  padding 2px 12px
  color var(--text-secondary, #8e8f92)
  background-color rgba(56, 58, 68, 0.4)
  font-size 11px
  user-select none

.deepreview-unified-line
  display flex
  align-items stretch
  min-height 20px

.deepreview-unified-line-added
  background-color rgba(63, 185, 80, 0.10)

.deepreview-unified-line-removed
  background-color rgba(248, 81, 73, 0.10)

.deepreview-unified-line-context
  background-color transparent

.deepreview-unified-gutter-old
.deepreview-unified-gutter-new
  display inline-block
  width 48px
  min-width 48px
  text-align right
  padding-right 8px
  color var(--text-secondary, #6e7681)
  user-select none
  border-right 1px solid var(--border-color, #2a2b34)
  flex-shrink 0
  font-size 11px
  line-height 20px

.deepreview-unified-line-added .deepreview-unified-gutter-old
.deepreview-unified-line-added .deepreview-unified-gutter-new
  background-color rgba(63, 185, 80, 0.06)

.deepreview-unified-line-removed .deepreview-unified-gutter-old
.deepreview-unified-line-removed .deepreview-unified-gutter-new
  background-color rgba(248, 81, 73, 0.06)

.deepreview-unified-line-content
  flex 1
  padding-left 12px
  white-space pre
  overflow-x auto
  color var(--text-primary, #c9c9c9)
  line-height 20px

.deepreview-unified-line-added .deepreview-unified-line-content
  color #3fb950

.deepreview-unified-line-removed .deepreview-unified-line-content
  color #f85149

// --- Context expansion buttons ---

.deepreview-expand-row
  display flex
  align-items center
  gap 6px
  padding 1px 12px
  cursor pointer
  user-select none
  color var(--text-secondary, #6e7681)
  font-family 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace
  font-size 11px
  line-height 20px
  background-color transparent
  transition color 0.15s ease, background-color 0.15s ease

  &:hover
    color var(--text-primary, #c9c9c9)
    background-color rgba(56, 58, 68, 0.3)

.deepreview-expand-icon
  color var(--text-secondary, #6e7681)
  width 48px
  min-width 48px
  text-align center
  flex-shrink 0

.deepreview-expand-label
  color inherit

// --- Expanded context lines (slightly dimmer than normal context) ---

.deepreview-expanded-context
  opacity 0.75

// --- Coverage line highlighting (Monaco decorations) ---

.deepreview-line-executed
  background-color rgba(0, 180, 0, 0.08)
  border-left 3px solid rgba(0, 200, 0, 0.5)

.deepreview-line-unreachable
  background-color rgba(220, 0, 0, 0.08)
  border-left 3px solid rgba(220, 0, 0, 0.5)

.deepreview-line-partial
  background-color rgba(220, 180, 0, 0.08)
  border-left 3px solid rgba(220, 180, 0, 0.5)

// --- Inline variable values (Monaco afterContent decorations) ---

.deepreview-inline-value
  color var(--text-secondary, #6e7681)
  font-style italic
  opacity 0.8
