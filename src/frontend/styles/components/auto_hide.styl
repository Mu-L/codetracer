// Auto-hide panes: edge strips, strip tabs, overlay, and backdrop.
// Styling follows Visual Studio's auto-hide behavior: overlays are flush
// with window edges, no border-radius, and side strip tabs use vertical text.

// ---------------------------------------------------------------------------
// Edge strips — thin bars at window edges that hold pinned-panel tabs.
// ---------------------------------------------------------------------------

.auto-hide-strips-container
  pointer-events: none
  position: absolute
  top: 0
  left: 0
  right: 0
  bottom: 0
  z-index: 50

.auto-hide-strip-left,
.auto-hide-strip-right,
.auto-hide-strip-bottom
  pointer-events: auto
  position: absolute
  display: flex
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  z-index: 50

// Left strip: vertical bar on the left edge, full height between menu and status bar.
.auto-hide-strip-left
  top: 34px  // below the menu bar
  left: 0
  bottom: 28px  // above the status bar
  width: 28px
  flex-direction: column
  align-items: center
  padding-top: 4px
  border-right: 1px solid PRIMARY_BASE

// Right strip: vertical bar on the right edge, full height between menu and status bar.
.auto-hide-strip-right
  top: 34px
  right: 0
  bottom: 28px
  width: 28px
  flex-direction: column
  align-items: center
  padding-top: 4px
  border-left: 1px solid PRIMARY_BASE

// Bottom strip: horizontal bar at the bottom (above status bar), full width.
.auto-hide-strip-bottom
  left: 0
  right: 0
  bottom: 28px
  height: 28px
  flex-direction: row
  align-items: center
  padding-left: 4px
  border-top: 1px solid PRIMARY_BASE

// Hide empty strips so they don't consume space or show borders.
.auto-hide-strip-left:empty,
.auto-hide-strip-right:empty,
.auto-hide-strip-bottom:empty
  display: none

// ---------------------------------------------------------------------------
// Strip tabs — individual clickable tabs within a strip.
// ---------------------------------------------------------------------------

.auto-hide-strip-tab
  font-family: "SpaceGrotesk"
  font-size: 12px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  background-color: HEADER_PANEL_INACTIVE_COLOR
  border-radius: 0
  cursor: pointer
  padding: 3px 6px
  margin: 2px
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis
  user-select: none
  transition: background-color 150ms ease

  &:hover
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

  &.active
    background-color: HEADER_ACTIVE_PANEL_BACKGROUND_COLOR
    color: HEADER_ACTIVE_PANEL_TEXT_COLOR

// Side strip tabs: VS Studio uses vertical text (rotated 90deg).
// Left side: text reads bottom-to-top (vertical-lr + rotate).
.auto-hide-strip-left .auto-hide-strip-tab
  writing-mode: vertical-lr
  text-orientation: mixed
  transform: rotate(180deg)
  max-height: 120px

// Right side: text reads top-to-bottom (vertical-rl).
.auto-hide-strip-right .auto-hide-strip-tab
  writing-mode: vertical-rl
  text-orientation: mixed
  max-height: 120px

// Bottom strip: tabs flow left-to-right, horizontal text.
.auto-hide-strip-bottom .auto-hide-strip-tab
  max-width: 160px

// ---------------------------------------------------------------------------
// Backdrop — semi-transparent overlay behind the slide-in panel.
// ---------------------------------------------------------------------------

#auto-hide-backdrop
  display: none
  position: fixed
  top: 0
  left: 0
  right: 0
  bottom: 0
  background-color: rgba(0, 0, 0, 0.25)
  z-index: 98

#auto-hide-overlay.visible ~ #auto-hide-backdrop
  display: block

// ---------------------------------------------------------------------------
// Overlay — the slide-in panel that appears when a strip tab is clicked.
// Flush with the window edge, no border-radius, no margin/padding gap.
// ---------------------------------------------------------------------------

#auto-hide-overlay
  position: fixed
  z-index: 99
  background-color: SECONDARY_BASE
  border: none
  border-radius: 0
  box-shadow: none
  margin: 0
  padding: 0
  display: none
  flex-direction: column
  overflow: hidden
  transition: transform 200ms ease

  &.visible
    display: flex

// Edge-specific positioning: each overlay is flush with its edge and
// spans the full available dimension along that edge.

// Left overlay: flush with left edge, full height (menu bar to bottom window edge).
// Only the right edge gets a border (separator from main content).
#auto-hide-overlay.auto-hide-overlay-left
  top: 34px
  left: 0
  bottom: 0
  width: 360px
  border-right: 1px solid PRIMARY_BASE

// Right overlay: flush with right edge, full height (menu bar to bottom window edge).
// Only the left edge gets a border.
#auto-hide-overlay.auto-hide-overlay-right
  top: 34px
  right: 0
  bottom: 0
  width: 360px
  border-left: 1px solid PRIMARY_BASE

// Bottom overlay: flush with bottom window edge, full width.
// Only the top edge gets a border.
#auto-hide-overlay.auto-hide-overlay-bottom
  left: 0
  right: 0
  bottom: 0
  height: 280px
  border-top: 1px solid PRIMARY_BASE

// ---------------------------------------------------------------------------
// Overlay header
// ---------------------------------------------------------------------------

#auto-hide-overlay-header
  display: flex
  align-items: center
  justify-content: space-between
  padding: 4px 8px
  background-color: HEADER_PANEL_BACKGROUND_COLOR
  border-bottom: 1px solid PRIMARY_BASE
  min-height: 32px
  flex-shrink: 0

#auto-hide-overlay-title
  font-family: "SpaceGrotesk"
  font-size: 13px
  font-weight: 600
  color: HEADER_PANEL_COLOR
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex: 1

.auto-hide-overlay-header-buttons
  display: flex
  gap: 4px
  align-items: center

#auto-hide-overlay-unpin-btn,
#auto-hide-overlay-close-btn
  cursor: pointer
  font-size: 12px
  padding: 2px 8px
  border-radius: 0
  color: HEADER_PANEL_COLOR
  background-color: transparent
  border: 1px solid PRIMARY_BASE
  transition: background-color 150ms ease

  &:hover
    background-color: ACTIVE_ROW

// ---------------------------------------------------------------------------
// Overlay content area
// ---------------------------------------------------------------------------

#auto-hide-overlay-content
  flex: 1
  overflow: auto
  padding: 0
