@import "../generated/index"

.ct-omni-value
    font-family: 'FiraCode'
    border-radius: 0.25em
    padding: 0.25em 0.5em
    background: color-editor-surface-primary
    display: flex
    align-items: center
    justify-content: center
    margin-right: 0.5em

.ct-omni-name
    color: color-ui-icon-primary-subtle

.ct-omni-name-std
    color: color-ui-icon-secondary

.ct-omni-name-error
    color: color-ui-text-error-primary-hover

[class*="ct-omni-name"]
    margin-right: 0.5em
